# ─── Authentification admin ────────────────────────────────────────────────────
# Mot de passe pour se connecter à /admin
ADMIN_PASSWORD=changeme2024

# Clé secrète pour signer les sessions (minimum 32 caractères aléatoires)
# Générer avec : openssl rand -hex 32
SESSION_SECRET=votre_cle_secrete_tres_longue_et_aleatoire_ici

# ─── Production (Railway) ──────────────────────────────────────────────────────
# URL publique du site (requis en production pour SvelteKit)
# Exemple : https://espoir-jeunes-benin.railway.app
ORIGIN=https://votre-app.railway.app

# Chemin vers le volume Railway persistant (laisser vide en développement local)
# Sur Railway : monter un volume sur /storage et mettre STORAGE_PATH=/storage
STORAGE_PATH=

# Numéro WhatsApp (sans + ni espaces, ex: 22900000000)
PUBLIC_WHATSAPP=22900000000
